{
  "id": "a1-sein-haben",
  "title": "The verbs sein and haben",
  "level": "A1",
  "summary": "Sein (to be) and haben (to have) are irregular and very common.",
  "sections": [
    {
      "heading": "sein",
      "body": [
        "ich bin, du bist, er/sie/es ist, wir sind, ihr seid, sie sind."
      ],
      "examples": [
        { "de": "Ich bin müde.", "en": "I am tired." },
        { "de": "Wir sind zu Hause.", "en": "We are at home." }
      ]
    },
    {
      "heading": "haben",
      "body": [
        "ich habe, du hast, er/sie/es hat, wir haben, ihr habt, sie haben."
      ],
      "examples": [
        { "de": "Ich habe Zeit.", "en": "I have time." },
        { "de": "Sie hat ein Auto.", "en": "She has a car." }
      ]
    }
  ],
