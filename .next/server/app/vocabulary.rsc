1c:["$","$La","a2-shopping",{"deck":{"id":"a2-shopping","title":"Shopping","level":"A2","topic":"shopping","cards":[{"id":"a2-sh-01","german":"kaufen","english":"to buy","gender":null,"example":"Ich möchte ein neues Hemd kaufen.","exampleEn":"I would like to buy a new shirt.","level":"A2","topic":"shopping"},{"id":"a2-sh-02","german":"verkaufen","english":"to sell","gender":null,"example":"Er verkauft sein altes Fahrrad.","exampleEn":"He is selling his old bicycle.","level":"A2","topic":"shopping"},{"id":"a2-sh-03","german":"der Preis","english":"price","gender":"masculine","example":"Der Preis für das Jacket ist zu hoch.","exampleEn":"The price for the jacket is too high.","level":"A2","topic":"shopping"},{"id":"a2-sh-04","german":"teuer","english":"expensive","gender":null,"example":"Diese Schuhe sind sehr teuer.","exampleEn":"These shoes are very expensive.","level":"A2","topic":"shopping"},{"id":"a2-sh-05","german":"billig","english":"cheap","gender":null,"example":"Auf dem Markt ist das Obst billig.","exampleEn":"At the market the fruit is cheap.","level":"A2","topic":"shopping"},{"id":"a2-sh-06","german":"die Größe","english":"size","gender":"feminine","example":"Welche Größe haben Sie?","exampleEn":"What size do you take?","level":"A2","topic":"shopping"},{"id":"a2-sh-07","german":"die Farbe","english":"colour","gender":"feminine","example":"Gibt es das T-Shirt in einer anderen Farbe?","exampleEn":"Does the T-shirt come in a different colour?","level":"A2","topic":"shopping"},{"id":"a2-sh-08","german":"anprobieren","english":"to try on","gender":null,"example":"Kann ich diese Hose anprobieren?","exampleEn":"Can I try on these trousers?","level":"A2","topic":"shopping"},{"id":"a2-sh-09","german":"die Kasse","english":"checkout / till","gender":"feminine","example":"Die Kasse ist dort hinten links.","exampleEn":"The checkout is over there at the back left.","level":"A2","topic":"shopping"},{"id":"a2-sh-10","german":"bezahlen","english":"to pay","gender":null,"example":"Kann ich mit Karte bezahlen?","exampleEn":"Can I pay by card?","level":"A2","topic":"shopping"},{"id":"a2-sh-11","german":"das Geschäft","english":"shop","gender":"neuter","example":"Das Geschäft öffnet um neun Uhr.","exampleEn":"The shop opens at nine o'clock.","level":"A2","topic":"shopping"},{"id":"a2-sh-12","german":"der Markt","english":"market","gender":"masculine","example":"Samstags gehen wir auf den Markt.","exampleEn":"On Saturdays we go to the market.","level":"A2","topic":"shopping"},{"id":"a2-sh-13","german":"das Angebot","english":"offer / deal","gender":"neuter","example":"Dieses Angebot gilt nur heute.","exampleEn":"This offer is valid today only.","level":"A2","topic":"shopping"},{"id":"a2-sh-14","german":"die Rechnung","english":"bill / receipt","gender":"feminine","example":"Können Sie mir bitte die Rechnung geben?","exampleEn":"Could you please give me the bill?","level":"A2","topic":"shopping"},{"id":"a2-sh-15","german":"zurückgeben","english":"to return","gender":null,"example":"Ich möchte diese Jacke zurückgeben.","exampleEn":"I would like to return this jacket.","level":"A2","topic":"shopping"}]}}]
1d:["$","$La","a2-health",{"deck":{"id":"a2-health","title":"Health & Body","level":"A2","topic":"health","cards":[{"id":"a2-he-01","german":"der Kopf","english":"head","gender":"masculine","example":"Mein Kopf tut weh.","exampleEn":"My head hurts.","level":"A2","topic":"health"},{"id":"a2-he-02","german":"der Arm","english":"arm","gender":"masculine","example":"Er hat sich den Arm gebrochen.","exampleEn":"He has broken his arm.","level":"A2","topic":"health"},{"id":"a2-he-03","german":"das Bein","english":"leg","gender":"neuter","example":"Mein Bein tut nach dem Sport weh.","exampleEn":"My leg hurts after doing sport.","level":"A2","topic":"health"},{"id":"a2-he-04","german":"der Bauch","english":"stomach","gender":"masculine","example":"Ich habe Bauchschmerzen nach dem Essen.","exampleEn":"I have stomach pain after eating.","level":"A2","topic":"health"},{"id":"a2-he-05","german":"der Rücken","english":"back","gender":"masculine","example":"Mein Rücken schmerzt vom langen Sitzen.","exampleEn":"My back aches from sitting for a long time.","level":"A2","topic":"health"},{"id":"a2-he-06","german":"die Schmerzen","english":"pain (plural)","gender":"plural","example":"Sie hat starke Schmerzen im Bein.","exampleEn":"She has strong pain in her leg.","level":"A2","topic":"health"},{"id":"a2-he-07","german":"krank","english":"sick","gender":null,"example":"Er ist krank und bleibt zu Hause.","exampleEn":"He is sick and stays at home.","level":"A2","topic":"health"},{"id":"a2-he-08","german":"gesund","english":"healthy","gender":null,"example":"Sport und gutes Essen halten uns gesund.","exampleEn":"Sport and good food keep us healthy.","level":"A2","topic":"health"},{"id":"a2-he-09","german":"der Arzt","english":"doctor (masc.)","gender":"masculine","example":"Der Arzt gibt mir ein Rezept.","exampleEn":"The doctor gives me a prescription.","level":"A2","topic":"health"},{"id":"a2-he-10","german":"die Ärztin","english":"doctor (fem.)","gender":"feminine","example":"Die Ärztin sagt, ich soll mehr Wasser trinken.","exampleEn":"The doctor says I should drink more water.","level":"A2","topic":"health"},{"id":"a2-he-11","german":"das Krankenhaus","english":"hospital","gender":"neuter","example":"Er liegt im Krankenhaus.","exampleEn":"He is in hospital.","level":"A2","topic":"health"},{"id":"a2-he-12","german":"die Apotheke","english":"pharmacy","gender":"feminine","example":"Ich hole das Medikament in der Apotheke.","exampleEn":"I pick up the medication from the pharmacy.","level":"A2","topic":"health"},{"id":"a2-he-13","german":"das Medikament","english":"medication","gender":"neuter","example":"Nehmen Sie das Medikament dreimal täglich.","exampleEn":"Take the medication three times a day.","level":"A2","topic":"health"},{"id":"a2-he-14","german":"Fieber haben","english":"to have a fever","gender":null,"example":"Das Kind hat hohes Fieber.","exampleEn":"The child has a high fever.","level":"A2","topic":"health"},{"id":"a2-he-15","german":"sich erholen","english":"to recover","gender":null,"example":"Sie erholt sich langsam von der Krankheit.","exampleEn":"She is slowly recovering from the illness.","level":"A2","topic":"health"}]}}]
1e:["$","$La","a2-hobbies",{"deck":{"id":"a2-hobbies","title":"Hobbies & Leisure","level":"A2","topic":"hobbies","cards":[{"id":"a2-ho-01","german":"das Hobby","english":"hobby","gender":"neuter","example":"Was ist dein Hobby?","exampleEn":"What is your hobby?","level":"A2","topic":"hobbies"},{"id":"a2-ho-02","german":"Sport treiben","english":"to do sport","gender":null,"example":"Er treibt dreimal pro Woche Sport.","exampleEn":"He does sport three times a week.","level":"A2","topic":"hobbies"},{"id":"a2-ho-03","german":"schwimmen","english":"to swim","gender":null,"example":"Im Sommer schwimme ich gern im See.","exampleEn":"In summer I like to swim in the lake.","level":"A2","topic":"hobbies"},{"id":"a2-ho-04","german":"lesen","english":"to read","gender":null,"example":"Ich lese jeden Abend ein Buch.","exampleEn":"I read a book every evening.","level":"A2","topic":"hobbies"},{"id":"a2-ho-05","german":"kochen","english":"to cook","gender":null,"example":"Sie kocht am Wochenende gern für Freunde.","exampleEn":"She likes to cook for friends at the weekend.","level":"A2","topic":"hobbies"},{"id":"a2-ho-06","german":"reisen","english":"to travel","gender":null,"example":"Wir reisen jedes Jahr nach Italien.","exampleEn":"We travel to Italy every year.","level":"A2","topic":"hobbies"},{"id":"a2-ho-07","german":"fotografieren","english":"to take photos","gender":null,"example":"Er fotografiert gern in der Stadt.","exampleEn":"He likes taking photos in the city.","level":"A2","topic":"hobbies"},{"id":"a2-ho-08","german":"das Konzert","english":"concert","gender":"neuter","example":"Wir gehen morgen in ein Konzert.","exampleEn":"We are going to a concert tomorrow.","level":"A2","topic":"hobbies"},{"id":"a2-ho-09","german":"das Kino","english":"cinema","gender":"neuter","example":"Möchtest du heute Abend ins Kino gehen?","exampleEn":"Would you like to go to the cinema tonight?","level":"A2","topic":"hobbies"},{"id":"a2-ho-10","german":"der Verein","english":"club / association","gender":"masculine","example":"Sie ist Mitglied in einem Sportverein.","exampleEn":"She is a member of a sports club.","level":"A2","topic":"hobbies"},{"id":"a2-ho-11","german":"spielen","english":"to play","gender":null,"example":"Die Kinder spielen im Park.","exampleEn":"The children are playing in the park.","level":"A2","topic":"hobbies"},{"id":"a2-ho-12","german":"das Spiel","english":"game","gender":"neuter","example":"Wir spielen nach dem Abendessen ein Spiel.","exampleEn":"We play a game after dinner.","level":"A2","topic":"hobbies"},{"id":"a2-ho-13","german":"wandern","english":"to hike","gender":null,"example":"Am Wochenende wandern wir in den Bergen.","exampleEn":"At the weekend we hike in the mountains.","level":"A2","topic":"hobbies"},{"id":"a2-ho-14","german":"zeichnen","english":"to draw","gender":null,"example":"Sie zeichnet gern Porträts von Menschen.","exampleEn":"She likes to draw portraits of people.","level":"A2","topic":"hobbies"},{"id":"a2-ho-15","german":"die Freizeit","english":"free time / leisure","gender":"feminine","example":"In meiner Freizeit höre ich Musik.","exampleEn":"In my free time I listen to music.","level":"A2","topic":"hobbies"}]}}]
1f:["$","$La","b1-media",{"deck":{"id":"b1-media","title":"Media & Technology","level":"B1","topic":"media","cards":[{"id":"b1-media-1","german":"die Nachrichten","english":"news","gender":"plural","example":"Ich schaue jeden Abend die Nachrichten im Fernsehen.","exampleEn":"I watch the news on television every evening.","level":"B1","topic":"media"},{"id":"b1-media-2","german":"das Internet","english":"internet","gender":"neuter","example":"Ohne Internet kann ich heutzutage kaum arbeiten.","exampleEn":"These days I can hardly work without the internet.","level":"B1","topic":"media"},{"id":"b1-media-3","german":"die App","english":"app","gender":"feminine","example":"Diese App hilft mir, meinen Alltag besser zu organisieren.","exampleEn":"This app helps me to organise my daily life better.","level":"B1","topic":"media"},{"id":"b1-media-4","german":"herunterladen","english":"to download","gender":null,"example":"Ich habe die App auf mein Handy heruntergeladen.","exampleEn":"I downloaded the app onto my phone.","level":"B1","topic":"media"},{"id":"b1-media-5","german":"soziale Medien","english":"social media","gender":"plural","example":"Viele Jugendliche verbringen viel Zeit auf sozialen Medien.","exampleEn":"Many young people spend a lot of time on social media.","level":"B1","topic":"media"},{"id":"b1-media-6","german":"die Werbung","english":"advertising","gender":"feminine","example":"Im Internet sieht man überall Werbung.","exampleEn":"On the internet you see advertising everywhere.","level":"B1","topic":"media"},{"id":"b1-media-7","german":"das Fernsehen","english":"television","gender":"neuter","example":"Das Fernsehen hat weniger Zuschauer, seit es Streaming gibt.","exampleEn":"Television has fewer viewers since streaming became available.","level":"B1","topic":"media"},{"id":"b1-media-8","german":"streamen","english":"to stream","gender":null,"example":"Wir streamen lieber Serien, als ins Kino zu gehen.","exampleEn":"We prefer to stream series rather than go to the cinema.","level":"B1","topic":"media"},{"id":"b1-media-9","german":"der Podcast","english":"podcast","gender":"masculine","example":"Auf dem Weg zur Arbeit höre ich immer einen Podcast.","exampleEn":"On the way to work I always listen to a podcast.","level":"B1","topic":"media"},{"id":"b1-media-10","german":"die Webseite","english":"website","gender":"feminine","example":"Die Webseite der Universität enthält alle wichtigen Informationen.","exampleEn":"The university's website contains all the important information.","level":"B1","topic":"media"},{"id":"b1-media-11","german":"teilen","english":"to share","gender":null,"example":"Er hat den interessanten Artikel in seinen sozialen Medien geteilt.","exampleEn":"He shared the interesting article on his social media.","level":"B1","topic":"media"},{"id":"b1-media-12","german":"kommentieren","english":"to comment","gender":null,"example":"Viele Leute kommentieren die Nachrichten online.","exampleEn":"Many people comment on the news online.","level":"B1","topic":"media"},{"id":"b1-media-13","german":"die Privatsphäre","english":"privacy","gender":"feminine","example":"Ich mache mir Sorgen um meine Privatsphäre im Internet.","exampleEn":"I am worried about my privacy on the internet.","level":"B1","topic":"media"},{"id":"b1-media-14","german":"hochladen","english":"to upload","gender":null,"example":"Sie hat ein neues Video auf ihre Seite hochgeladen.","exampleEn":"She uploaded a new video to her page.","level":"B1","topic":"media"},{"id":"b1-media-15","german":"digital","english":"digital","gender":null,"example":"Die digitale Transformation verändert viele Berufsfelder.","exampleEn":"The digital transformation is changing many professional fields.","level":"B1","topic":"media"}]}}]
20:["$","$La","b1-emotions",{"deck":{"id":"b1-emotions","title":"Emotions & Character","level":"B1","topic":"emotions","cards":[{"id":"b1-emotions-1","german":"die Freude","english":"joy","gender":"feminine","example":"Die Freude der Kinder an Weihnachten ist wunderschön.","exampleEn":"The joy of children at Christmas is wonderful.","level":"B1","topic":"emotions"},{"id":"b1-emotions-2","german":"die Trauer","english":"sadness","gender":"feminine","example":"Nach dem Tod seines Hundes war er voller Trauer.","exampleEn":"After the death of his dog, he was filled with sadness.","level":"B1","topic":"emotions"},{"id":"b1-emotions-3","german":"die Wut","english":"anger","gender":"feminine","example":"Er konnte seine Wut kaum kontrollieren.","exampleEn":"He could barely control his anger.","level":"B1","topic":"emotions"},{"id":"b1-emotions-4","german":"die Angst","english":"fear / anxiety","gender":"feminine","example":"Sie hat große Angst vor Spinnen.","exampleEn":"She is very afraid of spiders.","level":"B1","topic":"emotions"},{"id":"b1-emotions-5","german":"stolz","english":"proud","gender":null,"example":"Ich bin sehr stolz auf meinen Sohn.","exampleEn":"I am very proud of my son.","level":"B1","topic":"emotions"},{"id":"b1-emotions-6","german":"eifersüchtig","english":"jealous","gender":null,"example":"Er war eifersüchtig, weil seine Schwester bessere Noten hatte.","exampleEn":"He was jealous because his sister had better grades.","level":"B1","topic":"emotions"},{"id":"b1-emotions-7","german":"enttäuscht","english":"disappointed","gender":null,"example":"Sie war enttäuscht, als sie die Prüfung nicht bestanden hat.","exampleEn":"She was disappointed when she did not pass the exam.","level":"B1","topic":"emotions"},{"id":"b1-emotions-8","german":"aufgeregt","english":"excited","gender":null,"example":"Die Kinder waren sehr aufgeregt vor der Reise.","exampleEn":"The children were very excited before the trip.","level":"B1","topic":"emotions"},{"id":"b1-emotions-9","german":"nervös","english":"nervous","gender":null,"example":"Ich bin immer nervös, bevor ich einen Vortrag halte.","exampleEn":"I am always nervous before giving a presentation.","level":"B1","topic":"emotions"},{"id":"b1-emotions-10","german":"entspannt","english":"relaxed","gender":null,"example":"Nach dem Urlaub fühle ich mich viel entspannter.","exampleEn":"After the holiday I feel much more relaxed.","level":"B1","topic":"emotions"},{"id":"b1-emotions-11","german":"geduldig","english":"patient","gender":null,"example":"Ein guter Lehrer muss sehr geduldig sein.","exampleEn":"A good teacher must be very patient.","level":"B1","topic":"emotions"},{"id":"b1-emotions-12","german":"mutig","english":"brave","gender":null,"example":"Es war mutig von ihr, alleine durch Europa zu reisen.","exampleEn":"It was brave of her to travel through Europe alone.","level":"B1","topic":"emotions"},{"id":"b1-emotions-13","german":"ehrlich","english":"honest","gender":null,"example":"Es ist wichtig, ehrlich zu seinen Freunden zu sein.","exampleEn":"It is important to be honest with your friends.","level":"B1","topic":"emotions"},{"id":"b1-emotions-14","german":"zuverlässig","english":"reliable","gender":null,"example":"Er ist sehr zuverlässig und kommt nie zu spät.","exampleEn":"He is very reliable and never arrives late.","level":"B1","topic":"emotions"},{"id":"b1-emotions-15","german":"selbstbewusst","english":"self-confident","gender":null,"example":"Sie tritt immer sehr selbstbewusst auf.","exampleEn":"She always comes across as very self-confident.","level":"B1","topic":"emotions"}]}}]
21:["$","$La","b2-economy",{"deck":{"id":"b2-economy","title":"Economy & Business","level":"B2","topic":"economy","cards":[{"id":"b2-ec-01","german":"die Wirtschaft","english":"economy","gender":"feminine","example":"Die deutsche Wirtschaft ist stark vom Export abhängig.","exampleEn":"The German economy is heavily dependent on exports.","level":"B2","topic":"economy"},{"id":"b2-ec-02","german":"das Unternehmen","english":"company / enterprise","gender":"neuter","example":"Das Unternehmen plant, seinen Standort ins Ausland zu verlagern.","exampleEn":"The company is planning to relocate its site abroad.","level":"B2","topic":"economy"},{"id":"b2-ec-03","german":"der Markt","english":"market","gender":"masculine","example":"Der Markt für erneuerbare Energien wächst seit Jahren rasant.","exampleEn":"The market for renewable energies has been growing rapidly for years.","level":"B2","topic":"economy"},{"id":"b2-ec-04","german":"die Inflation","english":"inflation","gender":"feminine","example":"Die hohe Inflation hat die Kaufkraft der Bevölkerung geschwächt.","exampleEn":"High inflation has weakened the purchasing power of the population.","level":"B2","topic":"economy"},{"id":"b2-ec-05","german":"das Wachstum","english":"growth","gender":"neuter","example":"Das Wirtschaftswachstum lag im letzten Jahr bei zwei Prozent.","exampleEn":"Economic growth was two percent last year.","level":"B2","topic":"economy"},{"id":"b2-ec-06","german":"investieren","english":"to invest","gender":null,"example":"Viele Unternehmen investieren verstärkt in künstliche Intelligenz.","exampleEn":"Many companies are increasingly investing in artificial intelligence.","level":"B2","topic":"economy"},{"id":"b2-ec-07","german":"die Aktie","english":"share / stock","gender":"feminine","example":"Der Kurs der Aktie ist nach der Gewinnwarnung gefallen.","exampleEn":"The share price fell after the profit warning.","level":"B2","topic":"economy"},{"id":"b2-ec-08","german":"der Gewinn","english":"profit","gender":"masculine","example":"Das Unternehmen erzielte im dritten Quartal einen Rekordgewinn.","exampleEn":"The company achieved a record profit in the third quarter.","level":"B2","topic":"economy"},{"id":"b2-ec-09","german":"der Verlust","english":"loss","gender":"masculine","example":"Durch die Krise musste das Unternehmen erhebliche Verluste hinnehmen.","exampleEn":"Due to the crisis the company had to accept considerable losses.","level":"B2","topic":"economy"},{"id":"b2-ec-10","german":"die Nachfrage","english":"demand","gender":"feminine","example":"Die Nachfrage nach Elektroautos ist in den letzten Jahren stark gestiegen.","exampleEn":"Demand for electric cars has increased sharply in recent years.","level":"B2","topic":"economy"},{"id":"b2-ec-11","german":"das Angebot","english":"supply","gender":"neuter","example":"Das Angebot an Fachkräften kann die Nachfrage kaum decken.","exampleEn":"The supply of skilled workers can barely meet demand.","level":"B2","topic":"economy"},{"id":"b2-ec-12","german":"die Globalisierung","english":"globalisation","gender":"feminine","example":"Die Globalisierung hat den Welthandel grundlegend verändert.","exampleEn":"Globalisation has fundamentally changed world trade.","level":"B2","topic":"economy"},{"id":"b2-ec-13","german":"exportieren","english":"to export","gender":null,"example":"Deutschland exportiert Maschinen und Fahrzeuge in alle Welt.","exampleEn":"Germany exports machinery and vehicles all over the world.","level":"B2","topic":"economy"},{"id":"b2-ec-14","german":"importieren","english":"to import","gender":null,"example":"Das Land muss einen Großteil seines Energiebedarfs importieren.","exampleEn":"The country must import a large part of its energy needs.","level":"B2","topic":"economy"},{"id":"b2-ec-15","german":"der Haushalt","english":"budget / household","gender":"masculine","example":"Der Bundeshaushalt muss ohne neue Schulden ausgeglichen werden.","exampleEn":"The federal budget must be balanced without taking on new debt.","level":"B2","topic":"economy"}]}}]
22:["$","$La","b2-science",{"deck":{"id":"b2-science","title":"Science & Research","level":"B2","topic":"science","cards":[{"id":"b2-sc-01","german":"die Forschung","english":"research","gender":"feminine","example":"Die Forschung auf dem Gebiet der Quantencomputer macht große Fortschritte.","exampleEn":"Research in the field of quantum computing is making great progress.","level":"B2","topic":"science"},{"id":"b2-sc-02","german":"das Experiment","english":"experiment","gender":"neuter","example":"Das Experiment lieferte überraschende Ergebnisse, die die Theorie in Frage stellten.","exampleEn":"The experiment produced surprising results that called the theory into question.","level":"B2","topic":"science"},{"id":"b2-sc-03","german":"die Hypothese","english":"hypothesis","gender":"feminine","example":"Die Wissenschaftlerin stellte eine neue Hypothese zur Entstehung des Lebens auf.","exampleEn":"The scientist put forward a new hypothesis about the origin of life.","level":"B2","topic":"science"},{"id":"b2-sc-04","german":"beweisen","english":"to prove","gender":null,"example":"Es ist schwierig, diese Theorie mit den vorhandenen Daten zu beweisen.","exampleEn":"It is difficult to prove this theory with the available data.","level":"B2","topic":"science"},{"id":"b2-sc-05","german":"die Entdeckung","english":"discovery","gender":"feminine","example":"Die Entdeckung des Penicillins veränderte die Medizin für immer.","exampleEn":"The discovery of penicillin changed medicine forever.","level":"B2","topic":"science"},{"id":"b2-sc-06","german":"das Labor","english":"laboratory","gender":"neuter","example":"Im Labor werden täglich Hunderte von Proben untersucht.","exampleEn":"Hundreds of samples are examined in the laboratory every day.","level":"B2","topic":"science"},{"id":"b2-sc-07","german":"die Technologie","english":"technology","gender":"feminine","example":"Neue Technologien verändern die Art und Weise, wie wir arbeiten.","exampleEn":"New technologies are changing the way we work.","level":"B2","topic":"science"},{"id":"b2-sc-08","german":"künstliche Intelligenz","english":"artificial intelligence","gender":null,"example":"Künstliche Intelligenz wird zunehmend in der medizinischen Diagnostik eingesetzt.","exampleEn":"Artificial intelligence is increasingly being used in medical diagnostics.","level":"B2","topic":"science"},{"id":"b2-sc-09","german":"die Daten","english":"data","gender":"plural","example":"Die gesammelten Daten wurden sorgfältig ausgewertet und dokumentiert.","exampleEn":"The collected data was carefully evaluated and documented.","level":"B2","topic":"science"},{"id":"b2-sc-10","german":"analysieren","english":"to analyse","gender":null,"example":"Die Forscher analysierten die Proben mit modernsten Methoden.","exampleEn":"The researchers analysed the samples using state-of-the-art methods.","level":"B2","topic":"science"},{"id":"b2-sc-11","german":"die Theorie","english":"theory","gender":"feminine","example":"Darwins Theorie der Evolution ist heute wissenschaftlich anerkannt.","exampleEn":"Darwin's theory of evolution is now scientifically accepted.","level":"B2","topic":"science"},{"id":"b2-sc-12","german":"entwickeln","english":"to develop","gender":null,"example":"Das Team entwickelte einen neuen Impfstoff gegen die Krankheit.","exampleEn":"The team developed a new vaccine against the disease.","level":"B2","topic":"science"},{"id":"b2-sc-13","german":"die Innovation","english":"innovation","gender":"feminine","example":"Ohne Innovation kann ein Unternehmen langfristig nicht wettbewerbsfähig bleiben.","exampleEn":"Without innovation a company cannot remain competitive in the long term.","level":"B2","topic":"science"},{"id":"b2-sc-14","german":"messen","english":"to measure","gender":null,"example":"Die Forscher messen die Temperatur in regelmäßigen Abständen.","exampleEn":"The researchers measure the temperature at regular intervals.","level":"B2","topic":"science"},{"id":"b2-sc-15","german":"das Ergebnis","english":"result","gender":"neuter","example":"Das Ergebnis der Studie wurde in einer renommierten Fachzeitschrift veröffentlicht.","exampleEn":"The result of the study was published in a renowned specialist journal.","level":"B2","topic":"science"}]}}]
23:["$","$La","c1-idioms",{"deck":{"id":"c1-idioms","title":"Idioms & Expressions","level":"C1","topic":"idioms","cards":[{"id":"c1-id-01","german":"auf dem Laufenden bleiben","english":"to stay up to date","gender":null,"example":"Es ist wichtig, in diesem Berufsfeld auf dem Laufenden zu bleiben.","exampleEn":"It is important to stay up to date in this professional field.","level":"C1","topic":"idioms"},{"id":"c1-id-02","german":"den Nagel auf den Kopf treffen","english":"to hit the nail on the head","gender":null,"example":"Mit ihrer Einschätzung hat sie den Nagel auf den Kopf getroffen.","exampleEn":"With her assessment she hit the nail on the head.","level":"C1","topic":"idioms"},{"id":"c1-id-03","german":"unter vier Augen","english":"in private / face to face","gender":null,"example":"Das sollten wir lieber unter vier Augen besprechen.","exampleEn":"We should better discuss that in private.","level":"C1","topic":"idioms"},{"id":"c1-id-04","german":"ins Fettnäpfchen treten","english":"to put one's foot in it","gender":null,"example":"Er hat beim Abendessen mit seiner Bemerkung ins Fettnäpfchen getreten.","exampleEn":"He put his foot in it with his remark at dinner.","level":"C1","topic":"idioms"},{"id":"c1-id-05","german":"die Daumen drücken","english":"to keep fingers crossed","gender":null,"example":"Ich drücke dir die Daumen für deine Prüfung morgen!","exampleEn":"I'll keep my fingers crossed for your exam tomorrow!","level":"C1","topic":"idioms"},{"id":"c1-id-06","german":"auf Anhieb","english":"straight away / at once","gender":null,"example":"Sie hat die schwierige Aufgabe auf Anhieb gelöst.","exampleEn":"She solved the difficult task straight away.","level":"C1","topic":"idioms"},{"id":"c1-id-07","german":"jemandem auf die Nerven gehen","english":"to get on someone's nerves","gender":null,"example":"Das ständige Summen des Klimageräts geht mir auf die Nerven.","exampleEn":"The constant humming of the air conditioning is getting on my nerves.","level":"C1","topic":"idioms"},{"id":"c1-id-08","german":"nicht auf den Mund gefallen sein","english":"to be articulate / quick-witted","gender":null,"example":"In der Debatte zeigte sich, dass er wirklich nicht auf den Mund gefallen ist.","exampleEn":"The debate showed that he is truly quick-witted.","level":"C1","topic":"idioms"},{"id":"c1-id-09","german":"das Beste aus etwas machen","english":"to make the best of something","gender":null,"example":"Trotz der schwierigen Umstände haben wir das Beste daraus gemacht.","exampleEn":"Despite the difficult circumstances, we made the best of it.","level":"C1","topic":"idioms"},{"id":"c1-id-10","german":"in aller Munde sein","english":"to be on everyone's lips / talked about everywhere","gender":null,"example":"Nach dem Skandal war der Politiker in aller Munde.","exampleEn":"After the scandal the politician was on everyone's lips.","level":"C1","topic":"idioms"},{"id":"c1-id-11","german":"einen Haken haben","english":"to have a catch / snag","gender":null,"example":"Das Angebot klingt verlockend, aber es hat bestimmt einen Haken.","exampleEn":"The offer sounds tempting, but there is surely a catch.","level":"C1","topic":"idioms"},{"id":"c1-id-12","german":"auf eigene Faust","english":"on one's own initiative","gender":null,"example":"Er reiste auf eigene Faust durch Südamerika, ohne Reiseveranstalter.","exampleEn":"He travelled through South America on his own initiative, without a tour operator.","level":"C1","topic":"idioms"},{"id":"c1-id-13","german":"die Flinte ins Korn werfen","english":"to throw in the towel","gender":null,"example":"Auch wenn es schwierig wird, solltest du nicht die Flinte ins Korn werfen.","exampleEn":"Even when things get difficult, you should not throw in the towel.","level":"C1","topic":"idioms"},{"id":"c1-id-14","german":"schwer von Begriff sein","english":"to be slow on the uptake","gender":null,"example":"Er musste die Anweisung dreimal wiederholen, weil sein Kollege etwas schwer von Begriff war.","exampleEn":"He had to repeat the instruction three times because his colleague was a bit slow on the uptake.","level":"C1","topic":"idioms"},{"id":"c1-id-15","german":"Eulen nach Athen tragen","english":"to carry coals to Newcastle","gender":null,"example":"Einem Spitzenkoch ein Kochbuch schenken? Das wäre doch Eulen nach Athen tragen.","exampleEn":"Giving a top chef a cookery book? That would be carrying coals to Newcastle.","level":"C1","topic":"idioms"}]}}]
