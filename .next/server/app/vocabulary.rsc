el","gender":"neuter","example":"Das Hotel liegt direkt am Strand.","exampleEn":"The hotel is right on the beach.","level":"A2","topic":"travel"},{"id":"a2-tr-10","german":"das Zimmer","english":"room","gender":"neuter","example":"Ich möchte ein Zimmer für zwei Nächte.","exampleEn":"I would like a room for two nights.","level":"A2","topic":"travel"},{"id":"a2-tr-11","german":"buchen","english":"to book","gender":null,"example":"Hast du das Hotel schon gebucht?","exampleEn":"Have you already booked the hotel?","level":"A2","topic":"travel"},{"id":"a2-tr-12","german":"abfahren","english":"to depart","gender":null,"example":"Der Zug fährt in fünf Minuten ab.","exampleEn":"The train departs in five minutes.","level":"A2","topic":"travel"},{"id":"a2-tr-13","german":"ankommen","english":"to arrive","gender":null,"example":"Wir kommen morgen früh an.","exampleEn":"We arrive tomorrow morning.","level":"A2","topic":"travel"},{"id":"a2-tr-14","german":"der Fahrplan","english":"timetable","gender":"masculine","example":"Der Fahrplan hängt am Bahnhof.","exampleEn":"The timetable is posted at the station.","level":"A2","topic":"travel"},{"id":"a2-tr-15","german":"umsteigen","english":"to change / transfer","gender":null,"example":"Du musst in Frankfurt umsteigen.","exampleEn":"You have to change trains in Frankfurt.","level":"A2","topic":"travel"}]}}],["$","$La","a2-weather",{"deck":{"id":"a2-weather","title":"Weather","level":"A2","topic":"weather","cards":[{"id":"a2-we-01","german":"das Wetter","english":"weather","gender":"neuter","example":"Das Wetter heute ist sehr schön.","exampleEn":"The weather today is very nice.","level":"A2","topic":"weather"},{"id":"a2-we-02","german":"die Sonne","english":"sun","gender":"feminine","example":"Die Sonne scheint den ganzen Tag.","exampleEn":"The sun shines all day.","level":"A2","topic":"weather"},{"id":"a2-we-03","german":"der Regen","english":"rain","gender":"masculine","example":"Der Regen macht die Straße nass.","exampleEn":"The rain makes the street wet.","level":"A2","topic":"weather"},{"id":"a2-we-04","german":"der Schnee","english":"snow","gender":"masculine","example":"Im Winter gibt es viel Schnee.","exampleEn":"In winter there is a lot of snow.","level":"A2","topic":"weather"},{"id":"a2-we-05","german":"der Wind","english":"wind","gender":"masculine","example":"Der Wind ist heute sehr stark.","exampleEn":"The wind is very strong today.","level":"A2","topic":"weather"},{"id":"a2-we-06","german":"die Wolke","english":"cloud","gender":"feminine","example":"Am Himmel sind viele Wolken.","exampleEn":"There are many clouds in the sky.","level":"A2","topic":"weather"},{"id":"a2-we-07","german":"das Gewitter","english":"thunderstorm","gender":"neuter","example":"Das Gewitter kommt heute Abend.","exampleEn":"The thunderstorm is coming this evening.","level":"A2","topic":"weather"},{"id":"a2-we-08","german":"heiß","english":"hot","gender":null,"example":"Im Sommer ist es hier sehr heiß.","exampleEn":"In summer it is very hot here.","level":"A2","topic":"weather"},{"id":"a2-we-09","german":"kalt","english":"cold","gender":null,"example":"Es ist kalt, zieh eine Jacke an.","exampleEn":"It is cold, put on a jacket.","level":"A2","topic":"weather"},{"id":"a2-we-10","german":"warm","english":"warm","gender":null,"example":"Der April ist oft warm und sonnig.","exampleEn":"April is often warm and sunny.","level":"A2","topic":"weather"},{"id":"a2-we-11","german":"kühl","english":"cool","gender":null,"example":"Abends ist es kühl, bring einen Pullover mit.","exampleEn":"In the evenings it is cool, bring a jumper.","level":"A2","topic":"weather"},{"id":"a2-we-12","german":"es regnet","english":"it's raining","gender":null,"example":"Es regnet schon seit heute Morgen.","exampleEn":"It has been raining since this morning.","level":"A2","topic":"weather"},{"id":"a2-we-13","german":"es schneit","english":"it's snowing","gender":null,"example":"Es schneit! Die Kinder spielen draußen.","exampleEn":"It's snowing! The children play outside.","level":"A2","topic":"weather"},{"id":"a2-we-14","german":"die Temperatur","english":"temperature","gender":"feminine","example":"Die Temperatur liegt bei zehn Grad.","exampleEn":"The temperature is ten degrees.","level":"A2","topic":"weather"},{"id":"a2-we-15","german":"der Wetterbericht","english":"weather forecast","gender":"masculine","example":"Laut Wetterbericht regnet es morgen.","exampleEn":"According to the weather forecast it will rain tomorrow.","level":"A2","topic":"weather"}]}}],"$L1c","$L1d","$L1e"]}]]}]
13:["$","section","B1",{"className":"space-y-4","children":[["$","h2",null,{"className":"text-lg font-semibold","children":"B1"}],["$","div",null,{"className":"grid gap-4 sm:grid-cols-2 lg:grid-cols-3","children":[["$","$La","b1-work",{"deck":{"id":"b1-work","title":"Work & Career","level":"B1","topic":"work","cards":[{"id":"b1-work-1","german":"der Beruf","english":"profession","gender":"masculine","example":"Was ist dein Beruf?","exampleEn":"What is your profession?","level":"B1","topic":"work"},{"id":"b1-work-2","german":"die Stelle","english":"position / job","gender":"feminine","example":"Ich habe mich auf eine Stelle als Buchhalter beworben.","exampleEn":"I applied for a position as an accountant.","level":"B1","topic":"work"},{"id":"b1-work-3","german":"das Gehalt","english":"salary","gender":"neuter","example":"Mein Gehalt wird jeden Monat auf mein Konto überwiesen.","exampleEn":"My salary is transferred to my account every month.","level":"B1","topic":"work"},{"id":"b1-work-4","german":"die Bewerbung","english":"application","gender":"feminine","example":"Ich habe meine Bewerbung gestern abgeschickt.","exampleEn":"I sent off my application yesterday.","level":"B1","topic":"work"},{"id":"b1-work-5","german":"das Vorstellungsgespräch","english":"job interview","gender":"neuter","example":"Das Vorstellungsgespräch war schwierig, aber ich bin zuversichtlich.","exampleEn":"The job interview was difficult, but I am optimistic.","level":"B1","topic":"work"},{"id":"b1-work-6","german":"der Kollege","english":"colleague (male)","gender":"masculine","example":"Mein Kollege hilft mir immer, wenn ich Fragen habe.","exampleEn":"My colleague always helps me when I have questions.","level":"B1","topic":"work"},{"id":"b1-work-7","german":"die Kollegin","english":"colleague (female)","gender":"feminine","example":"Meine Kollegin und ich essen oft zusammen zu Mittag.","exampleEn":"My colleague and I often have lunch together.","level":"B1","topic":"work"},{"id":"b1-work-8","german":"der Chef","english":"boss (male)","gender":"masculine","example":"Mein Chef hat mir ein positives Feedback gegeben.","exampleEn":"My boss gave me positive feedback.","level":"B1","topic":"work"},{"id":"b1-work-9","german":"die Chefin","english":"boss (female)","gender":"feminine","example":"Die Chefin hat das Meeting auf morgen verschoben.","exampleEn":"The boss has postponed the meeting until tomorrow.","level":"B1","topic":"work"},{"id":"b1-work-10","german":"kündigen","english":"to quit / to resign","gender":null,"example":"Er hat seinen Job gekündigt, weil er eine bessere Stelle gefunden hat.","exampleEn":"He quit his job because he found a better position.","level":"B1","topic":"work"},{"id":"b1-work-11","german":"einstellen","english":"to hire","gender":null,"example":"Die Firma stellt dieses Jahr viele neue Mitarbeiter ein.","exampleEn":"The company is hiring many new employees this year.","level":"B1","topic":"work"},{"id":"b1-work-12","german":"die Erfahrung","english":"experience","gender":"feminine","example":"Für diese Stelle braucht man mindestens zwei Jahre Erfahrung.","exampleEn":"For this position, you need at least two years of experience.","level":"B1","topic":"work"},{"id":"b1-work-13","german":"die Ausbildung","english":"training / apprenticeship","gender":"feminine","example":"Sie macht eine Ausbildung zur Krankenpflegerin.","exampleEn":"She is doing an apprenticeship to become a nurse.","level":"B1","topic":"work"},{"id":"b1-work-14","german":"das Praktikum","english":"internship","gender":"neuter","example":"Ich mache ein Praktikum bei einer Marketingfirma.","exampleEn":"I am doing an internship at a marketing company.","level":"B1","topic":"work"},{"id":"b1-work-15","german":"die Karriere","english":"career","gender":"feminine","example":"Sie plant ihre Karriere sehr sorgfältig.","exampleEn":"She plans her career very carefully.","level":"B1","topic":"work"}]}}],["$","$La","b1-environment",{"deck":{"id":"b1-environment","title":"Environment & Nature","level":"B1","topic":"environment","cards":[{"id":"b1-environment-1","german":"die Umwelt","english":"environment","gender":"feminine","example":"Wir müssen die Umwelt für zukünftige Generationen schützen.","exampleEn":"We must protect the environment for future generations.","level":"B1","topic":"environment"},{"id":"b1-environment-2","german":"der Klimawandel","english":"climate change","gender":"masculine","example":"Der Klimawandel ist eine der größten Herausforderungen unserer Zeit.","exampleEn":"Climate change is one of the greatest challenges of our time.","level":"B1","topic":"environment"},{"id":"b1-environment-3","german":"die Energie","english":"energy","gender":"feminine","example":"Wir sollten mehr erneuerbare Energie nutzen.","exampleEn":"We should use more renewable energy.","level":"B1","topic":"environment"},{"id":"b1-environment-4","german":"erneuerbar","english":"renewable","gender":null,"example":"Solar- und Windkraft sind erneuerbare Energiequellen.","exampleEn":"Solar and wind power are renewable energy sources.","level":"B1","topic":"environment"},{"id":"b1-environment-5","german":"der Müll","english":"rubbish / waste","gender":"masculine","example":"Bitte wirf den Müll nicht auf die Straße.","exampleEn":"Please do not throw rubbish on the street.","level":"B1","topic":"environment"},{"id":"b1-environment-6","german":"recyceln","english":"to recycle","gender":null,"example":"In Deutschland ist es wichtig, Glas und Papier zu recyceln.","exampleEn":"In Germany it is important to recycle glass and paper.","level":"B1","topic":"environment"},{"id":"b1-environment-7","german":"der Wald","english":"forest","gender":"masculine","example":"Der Wald in dieser Region ist durch den sauren Regen gefährdet.","exampleEn":"The forest in this region is threatened by acid rain.","level":"B1","topic":"environment"},{"id":"b1-environment-8","german":"die Natur","english":"nature","gender":"feminine","example":"Am Wochenende gehe ich gerne in der Natur spazieren.","exampleEn":"At the weekend I like to go for walks in nature.","level":"B1","topic":"environment"},{"id":"b1-environment-9","german":"schützen","english":"to protect","gender":null,"example":"Wir müssen die Meere vor Plastikmüll schützen.","exampleEn":"We must protect the oceans from plastic waste.","level":"B1","topic":"environment"},{"id":"b1-environment-10","german":"die Verschmutzung","english":"pollution","gender":"feminine","example":"Die Luftverschmutzung in der Stadt ist ein ernstes Problem.","exampleEn":"Air pollution in the city is a serious problem.","level":"B1","topic":"environment"},{"id":"b1-environment-11","german":"nachhaltig","english":"sustainable","gender":null,"example":"Sie kauft am liebsten nachhaltige Produkte.","exampleEn":"She prefers to buy sustainable products.","level":"B1","topic":"environment"},{"id":"b1-environment-12","german":"das Tier","english":"animal","gender":"neuter","example":"Viele Tiere verlieren ihren Lebensraum durch die Abholzung.","exampleEn":"Many animals are losing their habitat due to deforestation.","level":"B1","topic":"environment"},{"id":"b1-environment-13","german":"die Pflanze","english":"plant","gender":"feminine","example":"Diese seltene Pflanze wächst nur in tropischen Regenwäldern.","exampleEn":"This rare plant only grows in tropical rainforests.","level":"B1","topic":"environment"},{"id":"b1-environment-14","german":"bedroht","english":"endangered / threatened","gender":null,"example":"Der Eisbär ist eine bedrohte Tierart.","exampleEn":"The polar bear is an endangered species.","level":"B1","topic":"environment"},{"id":"b1-environment-15","german":"sparen","english":"to save / to conserve","gender":null,"example":"Man kann viel Energie sparen, wenn man das Licht ausschaltet.","exampleEn":"You can save a lot of energy by turning off the lights.","level":"B1","topic":"environment"}]}}],"$L1f","$L20"]}]]}]
14:["$","section","B2",{"className":"space-y-4","children":[["$","h2",null,{"className":"text-lg font-semibold","children":"B2"}],["$","div",null,{"className":"grid gap-4 sm:grid-cols-2 lg:grid-cols-3","children":[["$","$La","b2-politics",{"deck":{"id":"b2-politics","title":"Politics & Society","level":"B2","topic":"politics","cards":[{"id":"b2-po-01","german":"die Demokratie","english":"democracy","gender":"feminine","example":"Die Demokratie lebt von der aktiven Beteiligung der Bürger.","exampleEn":"Democracy depends on the active participation of citizens.","level":"B2","topic":"politics"},{"id":"b2-po-02","german":"die Wahl","english":"election","gender":"feminine","example":"Bei der nächsten Wahl möchte ich mein Wahlrecht nutzen.","exampleEn":"At the next election I want to exercise my right to vote.","level":"B2","topic":"politics"},{"id":"b2-po-03","german":"die Regierung","english":"government","gender":"feminine","example":"Die Regierung hat neue Maßnahmen zur Bekämpfung der Inflation angekündigt.","exampleEn":"The government has announced new measures to combat inflation.","level":"B2","topic":"politics"},{"id":"b2-po-04","german":"das Parlament","english":"parliament","gender":"neuter","example":"Das Parlament hat das neue Gesetz mit großer Mehrheit verabschiedet.","exampleEn":"Parliament passed the new law by a large majority.","level":"B2","topic":"politics"},{"id":"b2-po-05","german":"die Partei","english":"party","gender":"feminine","example":"Welcher Partei gehört der neue Bürgermeister an?","exampleEn":"Which party does the new mayor belong to?","level":"B2","topic":"politics"},{"id":"b2-po-06","german":"abstimmen","english":"to vote","gender":null,"example":"Die Abgeordneten stimmten gestern über den Haushaltsentwurf ab.","exampleEn":"The MPs voted on the budget draft yesterday.","level":"B2","topic":"politics"},{"id":"b2-po-07","german":"der Bürger","english":"citizen (male)","gender":"masculine","example":"Jeder Bürger hat das Recht, seine Meinung frei zu äußern.","exampleEn":"Every citizen has the right to express their opinion freely.","level":"B2","topic":"politics"},{"id":"b2-po-08","german":"die Bürgerin","english":"citizen (female)","gender":"feminine","example":"Als engagierte Bürgerin setzt sie sich für soziale Gerechtigkeit ein.","exampleEn":"As an engaged citizen, she advocates for social justice.","level":"B2","topic":"politics"},{"id":"b2-po-09","german":"die Freiheit","english":"freedom","gender":"feminine","example":"Die Meinungsfreiheit ist ein grundlegendes Recht in einer Demokratie.","exampleEn":"Freedom of expression is a fundamental right in a democracy.","level":"B2","topic":"politics"},{"id":"b2-po-10","german":"die Gerechtigkeit","english":"justice","gender":"feminine","example":"Soziale Gerechtigkeit ist ein zentrales Thema im Wahlkampf.","exampleEn":"Social justice is a central topic in the election campaign.","level":"B2","topic":"politics"},{"id":"b2-po-11","german":"der Kompromiss","english":"compromise","gender":"masculine","example":"Nach langen Verhandlungen einigten sich die Parteien auf einen Kompromiss.","exampleEn":"After lengthy negotiations, the parties agreed on a compromise.","level":"B2","topic":"politics"},{"id":"b2-po-12","german":"die Reform","english":"reform","gender":"feminine","example":"Die geplante Reform des Bildungssystems ist umstritten.","exampleEn":"The planned reform of the education system is controversial.","level":"B2","topic":"politics"},{"id":"b2-po-13","german":"die Verfassung","english":"constitution","gender":"feminine","example":"Das Grundgesetz ist die Verfassung der Bundesrepublik Deutschland.","exampleEn":"The Basic Law is the constitution of the Federal Republic of Germany.","level":"B2","topic":"politics"},{"id":"b2-po-14","german":"das Gesetz","english":"law","gender":"neuter","example":"Dieses Gesetz schützt die Privatsphäre der Bürgerinnen und Bürger.","exampleEn":"This law protects the privacy of citizens.","level":"B2","topic":"politics"},{"id":"b2-po-15","german":"die Opposition","english":"opposition","gender":"feminine","example":"Die Opposition kritisierte den Gesetzentwurf scharf.","exampleEn":"The opposition criticised the bill sharply.","level":"B2","topic":"politics"}]}}],"$L21","$L22"]}]]}]
15:["$","section","C1",{"className":"space-y-4","children":[["$","h2",null,{"className":"text-lg font-semibold","children":"C1"}],["$","div",null,{"className":"grid gap-4 sm:grid-cols-2 lg:grid-cols-3","children":[["$","$La","c1-academic",{"deck":{"id":"c1-academic","title":"Academic Language","level":"C1","topic":"academic","cards":[{"id":"c1-ac-01","german":"die Argumentation","english":"argumentation","gender":"feminine","example":"Die Argumentation des Autors ist schlüssig und gut belegt.","exampleEn":"The author's argumentation is coherent and well substantiated.","level":"C1","topic":"academic"},{"id":"c1-ac-02","german":"die These","english":"thesis","gender":"feminine","example":"Die zentrale These der Abhandlung wird im zweiten Kapitel entfaltet.","exampleEn":"The central thesis of the treatise is developed in the second chapter.","level":"C1","topic":"academic"},{"id":"c1-ac-03","german":"widerlegen","english":"to refute","gender":null,"example":"Der Forscher konnte die bisherige Theorie durch neue Belege widerlegen.","exampleEn":"The researcher was able to refute the previous theory with new evidence.","level":"C1","topic":"academic"},{"id":"c1-ac-04","german":"belegen","english":"to substantiate / back up","gender":null,"example":"Jede Behauptung muss durch seriöse Quellen belegt werden.","exampleEn":"Every claim must be backed up by reliable sources.","level":"C1","topic":"academic"},{"id":"c1-ac-05","german":"die Schlussfolgerung","english":"conclusion","gender":"feminine","example":"Die Schlussfolgerung ergibt sich logisch aus den zuvor dargelegten Argumenten.","exampleEn":"The conclusion follows logically from the arguments set out previously.","level":"C1","topic":"academic"},{"id":"c1-ac-06","german":"abwägen","english":"to weigh up","gender":null,"example":"Es gilt, die Vor- und Nachteile sorgfältig abzuwägen, bevor man urteilt.","exampleEn":"One must carefully weigh up the advantages and disadvantages before passing judgement.","level":"C1","topic":"academic"},{"id":"c1-ac-07","german":"die Differenzierung","english":"differentiation","gender":"feminine","example":"Eine genaue Differenzierung zwischen beiden Begriffen ist für das Verständnis unerlässlich.","exampleEn":"A precise differentiation between the two terms is essential for understanding.","level":"C1","topic":"academic"},{"id":"c1-ac-08","german":"implizieren","english":"to imply","gender":null,"example":"Die Ergebnisse implizieren, dass der bisherige Ansatz überdacht werden muss.","exampleEn":"The results imply that the existing approach needs to be reconsidered.","level":"C1","topic":"academic"},{"id":"c1-ac-09","german":"der Diskurs","english":"discourse","gender":"masculine","example":"Im wissenschaftlichen Diskurs werden kontroverse Thesen offen diskutiert.","exampleEn":"In academic discourse, controversial theses are discussed openly.","level":"C1","topic":"academic"},{"id":"c1-ac-10","german":"die Perspektive","english":"perspective","gender":"feminine","example":"Das Problem sollte aus mehreren Perspektiven betrachtet werden.","exampleEn":"The problem should be examined from several perspectives.","level":"C1","topic":"academic"},{"id":"c1-ac-11","german":"kritisch","english":"critical","gender":null,"example":"Eine kritische Auseinandersetzung mit den Quellen ist unbedingt erforderlich.","exampleEn":"A critical engagement with the sources is absolutely necessary.","level":"C1","topic":"academic"},{"id":"c1-ac-12","german":"plausibel","english":"plausible","gender":null,"example":"Die Erklärung klingt plausibel, bedarf jedoch weiterer empirischer Überprüfung.","exampleEn":"The explanation sounds plausible but requires further empirical verification.","level":"C1","topic":"academic"},{"id":"c1-ac-13","german":"die Kohärenz","english":"coherence","gender":"feminine","example":"Die Kohärenz des Textes leidet unter dem häufigen Themenwechsel.","exampleEn":"The coherence of the text suffers from the frequent changes of topic.","level":"C1","topic":"academic"},{"id":"c1-ac-14","german":"veranschaulichen","english":"to illustrate","gender":null,"example":"Das Diagramm veranschaulicht den Zusammenhang zwischen den Variablen anschaulich.","exampleEn":"The diagram clearly illustrates the relationship between the variables.","level":"C1","topic":"academic"},{"id":"c1-ac-15","german":"die Prämisse","english":"premise","gender":"feminine","example":"Wenn die Prämisse falsch ist, kann die Schlussfolgerung nicht korrekt sein.","exampleEn":"If the premise is false, the conclusion cannot be correct.","level":"C1","topic":"academic"}]}}],"$L23"]}]]}]
16:["$","section","C2",{"className":"space-y-4","children":[["$","h2",null,{"className":"text-lg font-semibold","children":"C2"}],["$","div",null,{"className":"grid gap-4 sm:grid-cols-2 lg:grid-cols-3","children":[["$","$La","c2-nuanced",{"deck":{"id":"c2-nuanced","title":"Nuanced Expression","level":"C2","topic":"nuanced","cards":[{"id":"c2-nu-01","german":"die Ambivalenz","english":"ambivalence","gender":"feminine","example":"Die Ambivalenz seiner Gefühle gegenüber der neuen Stelle war spürbar.","exampleEn":"The ambivalence of his feelings towards the new position was palpable.","level":"C2","topic":"nuanced"},{"id":"c2-nu-02","german":"die Ambiguität","english":"ambiguity","gender":"feminine","example":"Die Ambiguität des Begriffs erlaubt verschiedene, einander widersprechende Interpretationen.","exampleEn":"The ambiguity of the term allows for various, mutually contradictory interpretations.","level":"C2","topic":"nuanced"},{"id":"c2-nu-03","german":"nuanciert","english":"nuanced","gender":null,"example":"Ihre nuancierte Analyse berücksichtigte sowohl die historischen als auch die sozialen Hintergründe.","exampleEn":"Her nuanced analysis took into account both the historical and social backgrounds.","level":"C2","topic":"nuanced"},{"id":"c2-nu-04","german":"die Konnotation","english":"connotation","gender":"feminine","example":"Das Wort trägt je nach Kontext eine positive oder negative Konnotation.","exampleEn":"The word carries a positive or negative connotation depending on the context.","level":"C2","topic":"nuanced"},{"id":"c2-nu-05","german":"subtil","english":"subtle","gender":null,"example":"Die subtile Ironie des Textes erschließt sich erst beim zweiten Lesen.","exampleEn":"The subtle irony of the text only reveals itself on a second reading.","level":"C2","topic":"nuanced"},{"id":"c2-nu-06","german":"die Implikation","english":"implication","gender":"feminine","example":"Die weitreichenden Implikationen dieser Entscheidung wurden lange unterschätzt.","exampleEn":"The far-reaching implications of this decision were underestimated for a long time.","level":"C2","topic":"nuanced"},{"id":"c2-nu-07","german":"vielschichtig","english":"multi-layered","gender":null,"example":"Der Roman ist vielschichtig und lässt sich auf mehreren Ebenen deuten.","exampleEn":"The novel is multi-layered and can be interpreted on several levels.","level":"C2","topic":"nuanced"},{"id":"c2-nu-08","german":"die Ironie","english":"irony","gender":"feminine","example":"Die Ironie des Schicksals wollte es, dass ausgerechnet er den Preis gewann.","exampleEn":"The irony of fate would have it that he of all people won the prize.","level":"C2","topic":"nuanced"},{"id":"c2-nu-09","german":"die Metapher","english":"metaphor","gender":"feminine","example":"Die Metapher des Lebens als Reise durchzieht den gesamten Text.","exampleEn":"The metaphor of life as a journey runs through the entire text.","level":"C2","topic":"nuanced"},{"id":"c2-nu-10","german":"paradigmatisch","english":"paradigmatic","gender":null,"example":"Dieser Fall gilt als paradigmatisch für den gesellschaftlichen Wandel jener Epoche.","exampleEn":"This case is considered paradigmatic for the social change of that era.","level":"C2","topic":"nuanced"},{"id":"c2-nu-11","german":"die Rhetorik","english":"rhetoric","gender":"feminine","example":"Seine Rhetorik war überzeugend, doch der Inhalt der Rede blieb vage.","exampleEn":"His rhetoric was convincing, yet the content of the speech remained vague.","level":"C2","topic":"nuanced"},{"id":"c2-nu-12","german":"eloquent","english":"eloquent","gender":null,"example":"Die eloquente Rednerin begeisterte das Publikum mit ihrer Wortwahl.","exampleEn":"The eloquent speaker captivated the audience with her choice of words.","level":"C2","topic":"nuanced"}]}}],["$","$La","c2-register",{"deck":{"id":"c2-register","title":"Formal Register & Style","level":"C2","topic":"register","cards":[{"id":"c2-re-01","german":"im Hinblick auf","english":"with regard to","gender":null,"example":"Im Hinblick auf die aktuellen Entwicklungen ist eine Neubewertung der Strategie erforderlich.","exampleEn":"With regard to current developments, a reassessment of the strategy is necessary.","level":"C2","topic":"register"},{"id":"c2-re-02","german":"diesbezüglich","english":"in this regard","gender":null,"example":"Diesbezüglich bitten wir um eine schriftliche Stellungnahme bis Ende des Monats.","exampleEn":"In this regard we ask for a written statement by the end of the month.","level":"C2","topic":"register"},{"id":"c2-re-03","german":"infolgedessen","english":"consequently / as a result","gender":null,"example":"Die Verhandlungen scheiterten; infolgedessen wurden die Lieferverträge ausgesetzt.","exampleEn":"The negotiations failed; consequently the supply contracts were suspended.","level":"C2","topic":"register"},{"id":"c2-re-04","german":"nichtsdestotrotz","english":"nevertheless","gender":null,"example":"Die Datenlage ist unvollständig; nichtsdestotrotz lassen sich erste Schlüsse ziehen.","exampleEn":"The data is incomplete; nevertheless some initial conclusions can be drawn.","level":"C2","topic":"register"},{"id":"c2-re-05","german":"gemäß","english":"in accordance with","gender":null,"example":"Gemäß den vertraglichen Vereinbarungen ist eine Kündigung erst nach sechs Monaten möglich.","exampleEn":"In accordance with the contractual agreements, termination is only possible after six months.","level":"C2","topic":"register"},{"id":"c2-re-06","german":"vorbehaltlich","english":"subject to","gender":null,"example":"Der Vertrag wird vorbehaltlich der Zustimmung des Aufsichtsrats unterzeichnet.","exampleEn":"The contract will be signed subject to the approval of the supervisory board.","level":"C2","topic":"register"},{"id":"c2-re-07","german":"die Erörterung","english":"discussion / deliberation","gender":"feminine","example":"Die Erörterung der ethischen Fragen nahm den größten Teil der Konferenz in Anspruch.","exampleEn":"The deliberation of the ethical questions took up the greater part of the conference.","level":"C2","topic":"register"},{"id":"c2-re-08","german":"die Abhandlung","english":"treatise / paper","gender":"feminine","example":"Die Abhandlung wurde in einem führenden Fachjournal zur Publikation angenommen.","exampleEn":"The treatise was accepted for publication in a leading specialist journal.","level":"C2","topic":"register"},{"id":"c2-re-09","german":"ausführlich","english":"detailed / in depth","gender":null,"example":"Der Bericht behandelt alle relevanten Aspekte ausführlich und in nachvollziehbarer Weise.","exampleEn":"The report covers all relevant aspects in depth and in a comprehensible manner.","level":"C2","topic":"register"},{"id":"c2-re-10","german":"darlegen","english":"to set out / expound","gender":null,"example":"Die Referentin legte ihre Position klar und überzeugend vor dem Ausschuss dar.","exampleEn":"The speaker set out her position clearly and convincingly before the committee.","level":"C2","topic":"register"},{"id":"c2-re-11","german":"die Stellungnahme","english":"statement / position","gender":"feminine","example":"Die Behörde hat noch keine offizielle Stellungnahme zu dem Vorfall abgegeben.","exampleEn":"The authority has not yet issued an official statement on the incident.","level":"C2","topic":"register"},{"id":"c2-re-12","german":"angemessen","english":"appropriate / adequate","gender":null,"example":"Es ist angemessen, in einem formellen Schreiben einen respektvollen Ton zu wahren.","exampleEn":"It is appropriate to maintain a respectful tone in a formal letter.","level":"C2","topic":"register"}]}}]]}]]}]
